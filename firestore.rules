rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 1. ATURAN BUAT RIWAYAT CHAT (History)
    // ==========================================
    
    // User yang login cuma bisa baca & nulis chat mereka sendiri
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Guest (tanpa login) cuma bisa baca & nulis chat di device mereka sendiri
    match /devices/{deviceId}/{document=**} {
      allow read, write: if true; // Diizinkan untuk guest, karena mereka ga punya akun auth
    }

    // ==========================================
    // 2. ATURAN BUAT SISTEM KUOTA (Anti-Abuse)
    // ==========================================
    
    match /quotas/{identifier} {
      // Semua orang bisa ngecek sisa kuota mereka sendiri
      allow read: if true;
      
      // Aturan update kuota:
      // Orang cuma bisa nambahin count (ngurangin kuota), 
      // nggak bisa nge-reset sendiri dari client (kecuali ganti hari)
      allow write: if 
        // Data harus valid (ada count, date, dll)
        request.resource.data.keys().hasAll(['count', 'date']) &&
        // Nggak bisa tiba-tiba nembak limit kuota dari client jadi 99999
        request.resource.data.count >= 0;
    }
    
    // ==========================================
    // 3. ATURAN BUAT API KEYS (API Provider)
    // ==========================================
    
    match /api_keys/{keyId} {
      // Cuma ROOT yang bisa create, delete, dan list semua key
      allow read, write: if request.auth != null && request.auth.token.email == 'johsua092@gmail.com';
      
      // Server Gateway (tanpa login) butuh akses untuk verifikasi (get) dan nambahin counter (update)
      allow get, update: if true;
    }
    
  }
}
