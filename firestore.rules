rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 1. ATURAN BUAT RIWAYAT CHAT (History)
    // ==========================================

    // User yang login cuma bisa akses data miliknya sendiri
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Guest (tanpa login): chat per device
    match /devices/{deviceId}/{document=**} {
      allow read, write: if true;
    }

    // ==========================================
    // 2. ATURAN BUAT KUOTA (Anti-Abuse)
    // ==========================================
    match /quotas/{identifier} {
      // Bisa dibaca semua untuk cek sisa kuota
      allow read: if true;
      
      // Bisa ditulis dengan constraint: harus ada count dan date, dan count tidak negatif
      allow write: if 
        request.resource.data.keys().hasAll(['count', 'date']) &&
        request.resource.data.count >= 0;
    }

    // ==========================================
    // 3. ATURAN BUAT API KEYS
    // ==========================================
    match /api_keys/{keyId} {
      // ROOT bisa create/read/delete semua key
      allow read, write: if request.auth != null && request.auth.token.email == 'johsua092@gmail.com';
      
      // Gateway (tanpa auth) butuh get + update untuk verifikasi key dan menambah usage
      allow get, update: if true;
    }
  }
}
